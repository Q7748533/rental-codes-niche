generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Brand {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique 
  defaultUrl  String?  
  codes       Code[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model Company {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique 
  industry    String?  
  codes       Code[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model Code {
  id           String   @id @default(cuid())
  codeValue    String   
  description  String?  
  isValid      Boolean  @default(true) 
  codeType     String   @default("Business") 
  source       String?  
  
  brandId      String
  brand        Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@unique([brandId, companyId, codeValue]) 
}

model AiQuery {
  id                String    @id @default(cuid())
  slug              String    @unique
  userPrompt        String
  aiSummary         String
  seoTitle          String
  seoContent        String
  viewCount         Int       @default(0)
  // GA4 数据字段
  ga4PageViews      Int       @default(0)
  ga4BounceRate     Float?
  ga4AvgDuration    Int?      // 平均停留时间（秒）
  lastAnalyzed      DateTime?
  isHighPerformer   Boolean   @default(false)
  // 关联搜索词
  searchQueryId     String?
  searchQuery       SearchQuery? @relation(fields: [searchQueryId], references: [id])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt
}

// 搜索词权重表（用于 AI 自学习）
model SearchQuery {
  id              String    @id @default(cuid())
  query           String    @unique // 搜索词
  weight          Float     @default(1.0) // 权重
  successCount    Int       @default(0) // 成功次数
  failCount       Int       @default(0) // 失败次数
  totalTraffic    Int       @default(0) // 总流量
  avgBounceRate   Float?    // 平均跳出率
  lastUsed        DateTime? // 最后使用时间
  articles        AiQuery[] // 关联的文章
  isActive        Boolean   @default(true) // 是否启用
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt
}

model PublicDeal {
  id          String   @id @default(cuid())
  title       String   
  description String   
  linkUrl     String   
  buttonText  String   
  isActive    Boolean  @default(true) 
  sortOrder   Int      @default(0)    
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

// AdSense 广告配置
model AdSenseConfig {
  id            String   @id @default(cuid())
  publisherId   String   @default("ca-pub-5289849412154503") // 发布商 ID
  isEnabled     Boolean  @default(false) // 全局开关
  autoAdsEnabled Boolean @default(true)  // Auto Ads 开关
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
}

// Google Analytics 配置
model GoogleAnalyticsConfig {
  id              String   @id @default(cuid())
  measurementId   String   @default("G-801N4HE033") // GA4 Measurement ID
  isEnabled       Boolean  @default(false) // 全局开关
  anonymizeIp     Boolean  @default(true)  // IP 匿名化（隐私合规）
  excludeAdmin    Boolean  @default(true)  // 排除管理员访问
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
}

// Meta 标签配置（用于网站验证等）
model MetaTag {
  id          String   @id @default(cuid())
  name        String   // meta name (如: verify-admitad, google-site-verification)
  content     String   // meta content (如: 155fd40ba8)
  isEnabled   Boolean  @default(true) // 是否启用
  description String?  // 备注说明
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  
  @@unique([name]) // 每个 name 只能有一个
}